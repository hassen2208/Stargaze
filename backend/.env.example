APP_NAME=Stargaze API
APP_VERSION=1.0.0
DEBUG=True

API_PREFIX=/api/v1

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stargaze_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

DATABASE_URL=postgresql://postgres:postgres@db:5432/stargaze_db

GEMINI_API_KEY=your_gemini_api_key

DEEPGRAM_API_KEY=your_deepgram_api_key

ELEVENLABS_API_KEY=your_elevenlabs_api_key

FIREBASE_CREDENTIALS_PATH=app/firebase/firebase_credentials.json